---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'T.O.I Coffee — Premium Vietnamese Coffee Experience',
  description = 'Discover the art of Vietnamese coffee at T.O.I Coffee. Hand-crafted beverages, premium beans, and a warm atmosphere await you.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth scroll-pt-24">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-warm-white text-espresso antialiased">
    <slot />
  </body>
</html>

<style is:global>
  /* Smooth animations for elements entering viewport */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
